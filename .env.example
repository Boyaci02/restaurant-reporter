# Metricool
METRICOOL_API_KEY=your-metricool-api-key
METRICOOL_USER_ID=your-metricool-user-id

# Google Business Profile
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./config/google-service-account.json

# Plausible Analytics
PLAUSIBLE_API_KEY=

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Mail (SendGrid SMTP)
SENDGRID_SMTP_HOST=smtp.sendgrid.net
SENDGRID_SMTP_PORT=587
SENDGRID_API_KEY=SG....
MAIL_FROM_NAME=Your Agency Name
MAIL_FROM_ADDRESS=reports@youragency.com

# Dashboard
DASHBOARD_PASSWORD=your-secure-password
PORT=3001

# Environment
NODE_ENV=production
LOG_LEVEL=info
